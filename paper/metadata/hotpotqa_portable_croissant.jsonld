  "@type": "sc:Dataset",
  "name": "hotpotqa_maxionbench",
  "alternateName": "HotpotQA-MaxionBench",
  "conformsTo": "http://mlcommons.org/croissant/1.0",
  "description": "A bounded retrieval-evaluation preprocessing of HotpotQA dev distractor used by MaxionBench S3 multi-evidence retrieval. Records include paragraph-level documents, natural-language questions, and qrels derived from supporting facts.",
  "version": "0.1",
  "dateCreated": "2026-04-29",
  "datePublished": "2026-04-29",
  "isLiveDataset": false,
  "creator": {
    "@type": "Organization",
    "name": "Anonymous NeurIPS submission"
  },
  "license": "https://creativecommons.org/licenses/by-sa/4.0/",
  "url": "https://anonymous.4open.science/r/retrieval-audit-artifact-8FDA",
  "citeAs": "@inproceedings{yang2018hotpotqa, title={HotpotQA: A Dataset for Diverse, Explainable Multi-hop Question Answering}, author={Yang, Zhilin and Qi, Peng and Zhang, Saizheng and Bengio, Yoshua and Cohen, William and Salakhutdinov, Ruslan and Manning, Christopher D.}, booktitle={EMNLP}, year={2018}}",
  "citation": "Yang et al., HotpotQA: A Dataset for Diverse, Explainable Multi-hop Question Answering, EMNLP 2018.",
  "keywords": [
    "retrieval evaluation",
    "multi-hop question answering",
    "agentic retrieval",
    "evidence coverage",
    "benchmark"
  ],
  "isBasedOn": {
    "@type": "sc:Dataset",
    "name": "HotpotQA dev distractor",
    "url": "https://hotpotqa.github.io/",
    "license": "https://creativecommons.org/licenses/by-sa/4.0/"
  },
  "measurementTechnique": "Evidence coverage at k over paragraph-level supporting facts.",
  "variableMeasured": [
    "evidence_coverage_at_10",
    "retrieval_latency_ms",
    "task_cost_est"
  ],
  "distribution": [
    {
      "@type": "cr:FileObject",
      "@id": "corpus_file",
      "name": "corpus.jsonl",
      "contentUrl": "dataset/processed/hotpot_portable/corpus.jsonl",
      "encodingFormat": "application/jsonlines",
      "sha256": "05cf6349cf1a292c046deeea13174ef84328afa80de04b2f988e30093cbda16d"
    },
    {
      "@type": "cr:FileObject",
      "@id": "queries_file",
      "name": "queries.jsonl",
      "contentUrl": "dataset/processed/hotpot_portable/queries.jsonl",
      "encodingFormat": "application/jsonlines",
      "sha256": "3cfd41505b31df3ddc43a61841233a593b6e3a238bab781f850b840a02e0b54b"
    },
    {
      "@type": "cr:FileObject",
      "@id": "qrels_file",
      "name": "qrels.tsv",
      "contentUrl": "dataset/processed/hotpot_portable/qrels.tsv",
      "encodingFormat": "text/tab-separated-values",
      "sha256": "b3a730a7d8da70297606f44d50d21aa99c32f44609e6d6d335e394da38234f7a"
    },
    {
      "@type": "cr:FileObject",
      "@id": "manifest_file",
      "name": "manifest.json",
      "contentUrl": "dataset/processed/hotpot_portable/manifest.json",
      "encodingFormat": "application/json",
      "sha256": "bc8d8b87f86af0c95b279b0aaf0593e3b410974df56c86c48cad7832eb4a3db0"
    },
    {
      "@type": "cr:FileObject",
      "@id": "checksums_file",
      "name": "checksums.json",
      "contentUrl": "dataset/processed/hotpot_portable/checksums.json",
      "encodingFormat": "application/json",
      "sha256": "14591060f0802dbedd8b7f415013b49434cfddc5b23975129dbb7720f1dc9647"
    }
  ],
  "recordSet": [
    {
      "@type": "cr:RecordSet",
      "@id": "corpus_records",
      "name": "corpus",
      "description": "Paragraph-level retrieval documents.",
      "key": "doc_id",
      "field": [
        {
          "@type": "cr:Field",
          "@id": "corpus/doc_id",
          "name": "doc_id",
          "dataType": "sc:Text",
          "description": "Stable document identifier.",
          "source": {
            "fileObject": {
              "@id": "corpus_file"
            },
            "extract": {
              "jsonPath": "$.doc_id"
            }
          }
        },
        {
          "@type": "cr:Field",
          "@id": "corpus/title",
          "name": "title",
          "dataType": "sc:Text",
          "description": "Source article title.",
          "source": {
            "fileObject": {
              "@id": "corpus_file"
            },
            "extract": {
              "jsonPath": "$.title"
            }
          }
        },
        {
          "@type": "cr:Field",
          "@id": "corpus/text",
          "name": "text",
          "dataType": "sc:Text",
          "description": "Paragraph text used for retrieval.",
          "source": {
            "fileObject": {
              "@id": "corpus_file"
            },
            "extract": {
              "jsonPath": "$.text"
            }
          }
        },
        {
          "@type": "cr:Field",
          "@id": "corpus/source",
          "name": "source",
          "dataType": "sc:Text",
          "description": "Dataset source marker.",
          "source": {
            "fileObject": {
              "@id": "corpus_file"
            },
            "extract": {
              "jsonPath": "$.source"
            }
          }
        }
      ]
    },
    {
      "@type": "cr:RecordSet",
      "@id": "query_records",
      "name": "queries",
      "description": "Natural-language multi-hop questions.",
      "key": "query_id",
      "field": [
        {
          "@type": "cr:Field",
          "@id": "queries/query_id",
          "name": "query_id",
          "dataType": "sc:Text",
          "description": "Stable query identifier.",
          "source": {
            "fileObject": {
              "@id": "queries_file"
            },
            "extract": {
              "jsonPath": "$.query_id"
            }
          }
        },
        {
          "@type": "cr:Field",
          "@id": "queries/text",
          "name": "text",
          "dataType": "sc:Text",
          "description": "Question text.",
          "source": {
            "fileObject": {
              "@id": "queries_file"
            },
            "extract": {
              "jsonPath": "$.text"
            }
          }
        },
        {
          "@type": "cr:Field",
          "@id": "queries/answer",
          "name": "answer",
          "dataType": "sc:Text",
          "description": "Original HotpotQA answer string.",
          "source": {
            "fileObject": {
              "@id": "queries_file"
            },
            "extract": {
              "jsonPath": "$.answer"
            }
          }
        }
      ]
    },
    {
      "@type": "cr:RecordSet",
      "@id": "qrel_records",
      "name": "qrels",
      "description": "Query-document relevance edges derived from supporting facts.",
      "key": [
        "query_id",
        "doc_id"
      ],
      "field": [
        {
          "@type": "cr:Field",
          "@id": "qrels/query_id",
          "name": "query_id",
          "dataType": "sc:Text",
          "description": "Query identifier.",
          "source": {
            "fileObject": {
              "@id": "qrels_file"
            },
            "extract": {
              "column": "query_id"
            }
          }
        },
        {
          "@type": "cr:Field",
          "@id": "qrels/doc_id",
          "name": "doc_id",
          "dataType": "sc:Text",
          "description": "Relevant document identifier.",
          "source": {
            "fileObject": {
              "@id": "qrels_file"
            },
            "extract": {
              "column": "doc_id"
            }
          }
        },
        {
          "@type": "cr:Field",
          "@id": "qrels/relevance",
          "name": "relevance",
          "dataType": "sc:Integer",
          "description": "Binary relevance score.",
          "source": {
            "fileObject": {
              "@id": "qrels_file"
            },
            "extract": {
              "column": "relevance"
            }
          }
        }
      ]
    }
  ],
  "rai:dataCollection": "HotpotQA-MaxionBench is deterministically derived from the official HotpotQA dev distractor source file. The preprocessing converts supporting-fact titles and contexts into paragraph-level retrieval qrels.",
  "rai:dataPreprocessing": "The MaxionBench preprocessing script emits corpus.jsonl, queries.jsonl, qrels.tsv, manifest.json, meta.json, and checksums.json. The archived manifest records 66,635 documents, 7,405 questions, and 14,810 qrels.",
  "rai:dataUseCases": "Intended for retrieval-infrastructure evaluation and evidence-coverage auditing. Not intended for training or evaluating answer-generation quality.",
  "rai:dataLimitation": "English Wikipedia-derived data, HotpotQA dev distractor only, paragraph-level evidence granularity, and local preprocessing assumptions. Conclusions should be limited to retrieval evidence coverage under the MaxionBench protocol."
}
